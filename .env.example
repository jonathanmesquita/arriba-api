# Arriba API
PORT=3000
NODE_ENV=production

# Chatbot / IA
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Freshdesk PH3A
FRESHDESK_DOMAIN=ph3a.freshdesk.com
FRESHDESK_API_KEY=

# Segurança opcional para webhooks do Freshdesk
FRESHDESK_WEBHOOK_SECRET=troque-este-token

# Modo seguro atual:
# false = a API pode buscar/analisar/renderizar, mas NAO grava nota, tags ou respostas no Freshdesk.
# true  = libera rotas de escrita. Use apenas quando a validacao manual estiver concluida.
FRESHDESK_ENABLE_WRITES=false

# Nota automatica por webhook.
# So funciona se FRESHDESK_ENABLE_WRITES=true.
SUPPORT_COPILOT_AUTO_NOTE=false

# Identidade usada nos placeholders renderizados
FRESHDESK_HELPDESK_NAME=PH3A
FRESHDESK_PORTAL_NAME=Portal PH3A

# Logs locais de analise, sem gravar nada no Freshdesk
SUPPORT_COPILOT_LOG_LIMIT=300

# Base de conhecimento Freshdesk/Solutions
# false = usa somente catalogo local versionado na Arriba API.
# true  = tenta consultar /api/v2/search/solutions no Freshdesk alem da base local.
FRESHDESK_USE_SOLUTIONS_API=false

# v2.2 - Freshdesk Knowledge Connector
# true = consulta tambem a base real de artigos do Freshdesk Solutions.
FRESHDESK_USE_SOLUTIONS_API=false
# IDs das pastas do Freshdesk Solutions que devem ser sincronizadas. Separe por virgula.
FRESHDESK_SOLUTIONS_FOLDER_IDS=48000676183
# Artigos importantes para sempre consultar/sincronizar. Separe por virgula.
FRESHDESK_SEED_ARTICLE_IDS=48001282071,48001170514,48001280258
# Cache em memoria para evitar chamar o Freshdesk a cada analise.
FRESHDESK_KB_CACHE_TTL_MINUTES=60
