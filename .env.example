# Arriba API
PORT=3000
NODE_ENV=production

# Chatbot / IA
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Freshdesk PH3A
FRESHDESK_DOMAIN=ph3a.freshdesk.com
FRESHDESK_API_KEY=

# Segurança opcional para webhooks do Freshdesk
FRESHDESK_WEBHOOK_SECRET=troque-este-token

# Modo seguro atual:
# false = a API pode buscar/analisar/renderizar, mas NAO grava nota, tags ou respostas no Freshdesk.
# true  = libera rotas de escrita. Use apenas quando a validacao manual estiver concluida.
FRESHDESK_ENABLE_WRITES=false

# Nota automatica por webhook.
# So funciona se FRESHDESK_ENABLE_WRITES=true.
SUPPORT_COPILOT_AUTO_NOTE=false

# Identidade usada nos placeholders renderizados
FRESHDESK_HELPDESK_NAME=PH3A
FRESHDESK_PORTAL_NAME=Portal PH3A

# Logs locais de analise, sem gravar nada no Freshdesk
SUPPORT_COPILOT_LOG_LIMIT=300
